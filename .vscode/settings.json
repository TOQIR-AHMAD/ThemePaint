    "editor.tokenColorCustomizations": {
        "comments": {
            "foreground": "#93a1a1",
            "fontStyle": "italic"
        },
        "strings": {
            "foreground": "#2aa198"
        },
        "numbers": {
            "foreground": "#d33682"
        },
        "keywords": {
            "foreground": "#859900"
        },
        "functions": {
            "foreground": "#268bd2"
        },
        "variables": {
            "foreground": "#657b83"
        },
        "types": {
            "foreground": "#b58900"
        },
        "textMateRules": [
            {
                "name": "ThemePaint Operators",
                "scope": "keyword.operator",
                "settings": {
                    "foreground": "#859900"
                }
            },
            {
                "name": "ThemePaint Classes",
                "scope": "entity.name.type.class",
                "settings": {
                    "foreground": "#b58900",
                    "fontStyle": "bold"
                }
            }
        ]
    },
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "function": {
                "foreground": "#268bd2"
            },
            "class": {
                "foreground": "#b58900"
            }
        }
    }
}