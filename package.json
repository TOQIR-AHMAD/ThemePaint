{
  "name": "themepaint",
  "displayName": "ThemePaint",
  "description": "A pack of 10 handcrafted color themes with a one-click theme picker in the sidebar.",
  "version": "0.2.0",
  "publisher": "ToqirAhmad",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#171326",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TOQIR-AHMAD/ThemePaint.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "color",
    "syntax",
    "tokencolor",
    "theme creator"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "themePaint",
          "title": "ThemePaint",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "themePaint": [
        {
          "id": "themePaint.view",
          "name": "Themes",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "themePaint.open",
        "title": "ThemePaint: Open Theme Picker"
      }
    ],
    "themes": [
      {
        "label": "Andromeda",
        "uiTheme": "vs-dark",
        "path": "./themes/andromeda.json"
      },
      {
