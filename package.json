{
  "name": "themepaint",
  "displayName": "ThemePaint",
  "description": "Build VS Code color themes by picking colors, with live preview. Covers the workbench UI and code syntax.",
  "version": "0.0.2",
  "publisher": "ToqirAhmad",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#171326",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TOQIR-AHMAD/ThemePaint.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "color",
    "syntax",
    "tokencolor",
    "theme creator"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "themePaint.open",
        "title": "ThemePaint: Open Theme Creator"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
