{
  "name": "themepaint",
  "displayName": "ThemePaint",
  "description": "A pack of 100 modern color themes in 20 categories, with a one-click theme picker in the sidebar.",
  "version": "0.3.1",
  "publisher": "ToqirAhmad",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#171326",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TOQIR-AHMAD/ThemePaint.git"
