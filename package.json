{
  "name": "themepaint",
  "displayName": "ThemePaint",
  "description": "A pack of 10 handcrafted color themes with a one-click theme picker in the sidebar.",
  "version": "0.1.0",
  "publisher": "ToqirAhmad",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#171326",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TOQIR-AHMAD/ThemePaint.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "keywords": [
    "theme",
    "color",
    "syntax",
    "tokencolor",
    "theme creator"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "themePaint",
          "title": "ThemePaint",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "themePaint": [
        {
          "id": "themePaint.view",
          "name": "Themes",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "themePaint.open",
        "title": "ThemePaint: Open Theme Picker"
      }
    ],
    "themes": [
      { "label": "Cobalt Forge", "uiTheme": "vs-dark", "path": "./themes/cobalt-forge.json" },
      { "label": "Onyx One", "uiTheme": "vs-dark", "path": "./themes/onyx-one.json" },
      { "label": "Vampire", "uiTheme": "vs-dark", "path": "./themes/vampire.json" },
      { "label": "Neon", "uiTheme": "vs-dark", "path": "./themes/neon.json" },
      { "label": "Frost", "uiTheme": "vs-dark", "path": "./themes/frost.json" },
      { "label": "Retro Amber", "uiTheme": "vs-dark", "path": "./themes/retro-amber.json" },
      { "label": "Deep Ocean", "uiTheme": "vs-dark", "path": "./themes/deep-ocean.json" },
      { "label": "Clean Light", "uiTheme": "vs", "path": "./themes/clean-light.json" },
      { "label": "Solar Day", "uiTheme": "vs", "path": "./themes/solar-day.json" },
      { "label": "High Contrast Forge", "uiTheme": "hc-black", "path": "./themes/high-contrast-forge.json" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.84.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
