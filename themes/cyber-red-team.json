{
  "name": "Cyber: Red Team",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0d0d0d",
    "editor.foreground": "#ededed",
    "editorLineNumber.foreground": "#7a3b3b",
    "editorLineNumber.activeForeground": "#ff003c",
    "editor.selectionBackground": "#3a0a12",
    "editor.lineHighlightBackground": "#160d0d",
    "editorCursor.foreground": "#ff003c",
    "editor.findMatchBackground": "#ff003c66",
    "editorWhitespace.foreground": "#ededed1a",
    "editorBracketHighlight.foreground1": "#ff79c6",
    "editorBracketHighlight.foreground2": "#ff9e80",
    "editorBracketHighlight.foreground3": "#ff003c",
    "activityBar.background": "#080808",
    "activityBar.foreground": "#ff003c",
    "activityBar.inactiveForeground": "#7a3b3b",
    "activityBarBadge.background": "#ff003c",
    "activityBarBadge.foreground": "#0d0d0d",
    "sideBar.background": "#140a0a",
    "sideBar.foreground": "#ededed",
    "sideBarTitle.foreground": "#ff003c",
    "sideBarSectionHeader.background": "#0d0d0d",
    "statusBar.background": "#080808",
    "statusBar.foreground": "#ededed",
    "statusBar.noFolderBackground": "#080808",
    "titleBar.activeBackground": "#080808",
    "titleBar.activeForeground": "#ededed",
    "editorGroupHeader.tabsBackground": "#140a0a",
    "tab.activeBackground": "#0d0d0d",
    "tab.activeForeground": "#ff003c",
    "tab.inactiveBackground": "#140a0a",
    "tab.inactiveForeground": "#7a3b3b",
    "tab.activeBorderTop": "#ff003c",
    "panel.background": "#140a0a",
    "terminal.background": "#0d0d0d",
    "terminal.foreground": "#ededed",
    "button.background": "#ff003c",
    "button.foreground": "#0d0d0d",
    "button.hoverBackground": "#ff5555",
    "input.background": "#080808",
    "input.foreground": "#ededed",
    "focusBorder": "#ff003c",
    "list.activeSelectionBackground": "#3a0a12",
    "list.hoverBackground": "#160d0d",
    "badge.background": "#ff003c",
    "badge.foreground": "#0d0d0d"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a3b3b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#ff9e80"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ffb86c"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "support.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#ff003c"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ff5555"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff5370"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#ededed"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#ffb3c1",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#ff8a5b"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#f7c948"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.type.class",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#ff2d6f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ff003c"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f7c948"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7a3b3b"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#ff79c6",
    "method": "#ff79c6",
    "class": "#ff2d6f",
    "interface": "#f7c948",
    "type": "#f7c948",
    "enum": "#f7c948",
    "variable": "#ededed",
    "parameter": "#ffb3c1",
    "property": "#ff8a5b",
    "namespace": "#ff5370"
  }
}
