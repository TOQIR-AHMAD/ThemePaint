{
  "name": "Ayu Mirage",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1f2430",
    "editor.foreground": "#cccac2",
    "editorLineNumber.foreground": "#707a8c",
    "editorLineNumber.activeForeground": "#ffcc66",
    "editor.selectionBackground": "#2d3640",
    "editor.lineHighlightBackground": "#242b38",
    "editorCursor.foreground": "#ffcc66",
    "editor.findMatchBackground": "#ffcc6666",
    "editorWhitespace.foreground": "#cccac21a",
    "activityBar.background": "#151a23",
    "activityBar.foreground": "#ffcc66",
    "activityBar.inactiveForeground": "#707a8c",
    "activityBarBadge.background": "#ffcc66",
    "activityBarBadge.foreground": "#1f2430",
    "sideBar.background": "#1a1f29",
    "sideBar.foreground": "#cccac2",
    "sideBarTitle.foreground": "#ffcc66",
    "sideBarSectionHeader.background": "#1f2430",
    "statusBar.background": "#151a23",
    "statusBar.foreground": "#cccac2",
    "statusBar.noFolderBackground": "#151a23",
    "titleBar.activeBackground": "#151a23",
    "titleBar.activeForeground": "#cccac2",
    "editorGroupHeader.tabsBackground": "#1a1f29",
    "tab.activeBackground": "#1f2430",
    "tab.activeForeground": "#ffcc66",
    "tab.inactiveBackground": "#1a1f29",
    "tab.inactiveForeground": "#707a8c",
    "tab.activeBorderTop": "#ffcc66",
    "panel.background": "#1a1f29",
    "terminal.background": "#1f2430",
    "terminal.foreground": "#cccac2",
    "button.background": "#ffcc66",
    "button.foreground": "#1f2430",
    "button.hoverBackground": "#73d0ff",
    "input.background": "#151a23",
    "input.foreground": "#cccac2",
    "focusBorder": "#ffcc66",
    "list.activeSelectionBackground": "#2d3640",
    "list.hoverBackground": "#242b38",
    "badge.background": "#ffcc66",
    "badge.foreground": "#1f2430"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#5c6773",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#d5ff80"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#ffd173"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ffa759"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#ffd173"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#cccac2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#73d0ff"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#f29e74"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#73d0ff",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#ffd173",
    "class": "#73d0ff"
  }
}
