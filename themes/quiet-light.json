{
  "name": "Quiet Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#f5f5f5",
    "editor.foreground": "#333333",
    "editorLineNumber.foreground": "#aaaaaa",
    "editorLineNumber.activeForeground": "#4b83cd",
    "editor.selectionBackground": "#c9d0d9",
    "editor.lineHighlightBackground": "#e4f6d4",
    "editorCursor.foreground": "#333333",
    "editor.findMatchBackground": "#4b83cd66",
    "editorWhitespace.foreground": "#3333331a",
    "activityBar.background": "#e4e4e4",
    "activityBar.foreground": "#4b83cd",
    "activityBar.inactiveForeground": "#aaaaaa",
    "activityBarBadge.background": "#4b83cd",
    "activityBarBadge.foreground": "#f5f5f5",
    "sideBar.background": "#ececec",
    "sideBar.foreground": "#333333",
    "sideBarTitle.foreground": "#4b83cd",
    "sideBarSectionHeader.background": "#f5f5f5",
    "statusBar.background": "#e4e4e4",
    "statusBar.foreground": "#333333",
    "statusBar.noFolderBackground": "#e4e4e4",
    "titleBar.activeBackground": "#e4e4e4",
    "titleBar.activeForeground": "#333333",
    "editorGroupHeader.tabsBackground": "#ececec",
    "tab.activeBackground": "#f5f5f5",
    "tab.activeForeground": "#4b83cd",
    "tab.inactiveBackground": "#ececec",
    "tab.inactiveForeground": "#aaaaaa",
    "tab.activeBorderTop": "#4b83cd",
    "panel.background": "#ececec",
    "terminal.background": "#f5f5f5",
    "terminal.foreground": "#333333",
    "button.background": "#4b83cd",
    "button.foreground": "#f5f5f5",
    "button.hoverBackground": "#7a3e9d",
    "input.background": "#e4e4e4",
    "input.foreground": "#333333",
    "focusBorder": "#4b83cd",
    "list.activeSelectionBackground": "#c9d0d9",
    "list.hoverBackground": "#e4f6d4",
    "badge.background": "#4b83cd",
    "badge.foreground": "#f5f5f5"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#aaaaaa",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#448c27"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#ab6526"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#4b69c6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#aa3731"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#333333"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#7a3e9d"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#777777"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#7a3e9d",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#aa3731",
    "class": "#7a3e9d"
  }
}
