    "sideBar.background": "#1a1a28",
    "sideBar.foreground": "#cdd6f4",
    "sideBarTitle.foreground": "#cba6f7",
    "sideBarSectionHeader.background": "#1e1e2e",
    "statusBar.background": "#161621",
    "statusBar.foreground": "#cdd6f4",
    "statusBar.noFolderBackground": "#161621",
    "titleBar.activeBackground": "#161621",
    "titleBar.activeForeground": "#cdd6f4",
    "titleBar.inactiveBackground": "#161621",
    "titleBar.inactiveForeground": "#6d7187",
    "editorGroupHeader.tabsBackground": "#1b1b29",
    "tab.activeBackground": "#1e1e2e",
    "tab.activeForeground": "#cba6f7",
    "tab.inactiveBackground": "#1b1b29",
    "tab.inactiveForeground": "#6d7187",
    "tab.activeBorderTop": "#cba6f7",
    "tab.border": "#1b1b29",
    "panel.background": "#1a1a28",
    "panelTitle.activeForeground": "#cba6f7",
    "terminal.background": "#1e1e2e",
    "terminal.foreground": "#cdd6f4",
    "button.background": "#cba6f7",
    "button.foreground": "#1a1a1a",
    "button.hoverBackground": "#d1b1f8",
    "input.background": "#161621",
    "input.foreground": "#cdd6f4",
    "input.placeholderForeground": "#6d7187",
    "dropdown.background": "#161621",
    "focusBorder": "#cba6f7",
    "list.activeSelectionBackground": "#cba6f742",
    "list.activeSelectionForeground": "#cdd6f4",
    "list.hoverBackground": "#2c2c3b",
    "list.inactiveSelectionBackground": "#cba6f724",
    "badge.background": "#cba6f7",
    "badge.foreground": "#1a1a1a",
    "scrollbarSlider.background": "#cdd6f429",
    "scrollbarSlider.hoverBackground": "#cdd6f442",
    "scrollbarSlider.activeBackground": "#cdd6f45c",
    "editorWidget.background": "#161621",
    "editorSuggestWidget.selectedBackground": "#cba6f742",
    "selection.background": "#cba6f74d"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6c7086",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#cdd6f4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#aeb5d0"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89dceb"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#cba6f7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#1e1e2e",
        "background": "#cba6f7"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#89b4fa",
    "method": "#89b4fa",
    "class": "#f9e2af",
    "property": "#f38ba8",
    "parameter": "#aeb5d0",
    "variable": "#cdd6f4"
  }
}
