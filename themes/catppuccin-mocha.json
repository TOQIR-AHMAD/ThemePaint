{
  "name": "Catppuccin Mocha",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1e1e2e",
    "editor.foreground": "#cdd6f4",
    "editorLineNumber.foreground": "#6c7086",
    "editorLineNumber.activeForeground": "#89b4fa",
    "editor.selectionBackground": "#313244",
    "editor.lineHighlightBackground": "#28283c",
    "editorCursor.foreground": "#f5e0dc",
    "editor.findMatchBackground": "#89b4fa66",
    "editorWhitespace.foreground": "#cdd6f41a",
    "activityBar.background": "#11111b",
    "activityBar.foreground": "#89b4fa",
    "activityBar.inactiveForeground": "#6c7086",
    "activityBarBadge.background": "#89b4fa",
    "activityBarBadge.foreground": "#1e1e2e",
    "sideBar.background": "#181825",
    "sideBar.foreground": "#cdd6f4",
    "sideBarTitle.foreground": "#89b4fa",
    "sideBarSectionHeader.background": "#1e1e2e",
    "statusBar.background": "#11111b",
    "statusBar.foreground": "#cdd6f4",
    "statusBar.noFolderBackground": "#11111b",
    "titleBar.activeBackground": "#11111b",
    "titleBar.activeForeground": "#cdd6f4",
    "editorGroupHeader.tabsBackground": "#181825",
    "tab.activeBackground": "#1e1e2e",
    "tab.activeForeground": "#89b4fa",
    "tab.inactiveBackground": "#181825",
    "tab.inactiveForeground": "#6c7086",
    "tab.activeBorderTop": "#89b4fa",
    "panel.background": "#181825",
    "terminal.background": "#1e1e2e",
    "terminal.foreground": "#cdd6f4",
    "button.background": "#89b4fa",
    "button.foreground": "#1e1e2e",
    "button.hoverBackground": "#f5c2e7",
    "input.background": "#11111b",
    "input.foreground": "#cdd6f4",
    "focusBorder": "#89b4fa",
    "list.activeSelectionBackground": "#313244",
    "list.hoverBackground": "#28283c",
    "badge.background": "#89b4fa",
    "badge.foreground": "#1e1e2e"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6c7086",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#cba6f7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#cdd6f4"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89dceb"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#89b4fa",
    "class": "#f9e2af"
  }
}
