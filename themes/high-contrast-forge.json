{
  "name": "High Contrast Forge",
  "type": "hc-black",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#ffffff",
    "editorLineNumber.foreground": "#ffffff",
    "editorLineNumber.activeForeground": "#ffff00",
    "editor.selectionBackground": "#ffffff40",
    "editor.lineHighlightBackground": "#1a1a1a",
    "editorCursor.foreground": "#ffff00",
    "editor.findMatchBackground": "#ffff0099",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#ffffff",
    "activityBar.inactiveForeground": "#cccccc",
    "activityBarBadge.background": "#ffff00",
    "activityBarBadge.foreground": "#000000",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#ffffff",
    "sideBarTitle.foreground": "#ffffff",
    "sideBarSectionHeader.background": "#000000",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#000000",
    "statusBar.border": "#6fc3df",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#ffffff",
    "titleBar.border": "#6fc3df",
    "editorGroupHeader.tabsBackground": "#000000",
    "tab.activeBackground": "#000000",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#cccccc",
    "tab.border": "#6fc3df",
    "tab.activeBorderTop": "#ffff00",
    "panel.background": "#000000",
    "terminal.background": "#000000",
    "terminal.foreground": "#ffffff",
    "button.background": "#000000",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#1a1a1a",
    "input.background": "#000000",
    "input.foreground": "#ffffff",
    "input.border": "#6fc3df",
    "focusBorder": "#f38518",
    "list.activeSelectionBackground": "#ffffff40",
    "list.hoverBackground": "#1a1a1a",
    "badge.background": "#ffff00",
    "badge.foreground": "#000000"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#7ca668", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#ce9178" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#b5cea8" } },
    { "scope": "keyword", "settings": { "foreground": "#569cd6" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#dcdcaa" } },
    { "scope": ["variable", "meta.definition.variable.name"], "settings": { "foreground": "#ffffff" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#4ec9b0" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#ffffff" } },
    { "scope": "entity.name.type.class", "settings": { "foreground": "#4ec9b0", "fontStyle": "bold" } }
  ],
  "semanticTokenColors": {
    "function": "#dcdcaa",
    "class": "#4ec9b0"
  }
}
