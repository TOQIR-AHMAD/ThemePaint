{
  "name": "Synthwave",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#262335",
    "editor.foreground": "#ffffff",
    "editorLineNumber.foreground": "#848bbd",
    "editorLineNumber.activeForeground": "#ff7edb",
    "editor.selectionBackground": "#463465",
    "editor.lineHighlightBackground": "#2e2b40",
    "editorCursor.foreground": "#f97e72",
    "editor.findMatchBackground": "#ff7edb66",
    "editorWhitespace.foreground": "#ffffff1a",
    "activityBar.background": "#191526",
    "activityBar.foreground": "#ff7edb",
    "activityBar.inactiveForeground": "#848bbd",
    "activityBarBadge.background": "#ff7edb",
    "activityBarBadge.foreground": "#262335",
    "sideBar.background": "#1f1c2e",
    "sideBar.foreground": "#ffffff",
    "sideBarTitle.foreground": "#ff7edb",
    "sideBarSectionHeader.background": "#262335",
    "statusBar.background": "#191526",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#191526",
    "titleBar.activeBackground": "#191526",
    "titleBar.activeForeground": "#ffffff",
    "editorGroupHeader.tabsBackground": "#1f1c2e",
    "tab.activeBackground": "#262335",
    "tab.activeForeground": "#ff7edb",
    "tab.inactiveBackground": "#1f1c2e",
    "tab.inactiveForeground": "#848bbd",
    "tab.activeBorderTop": "#ff7edb",
    "panel.background": "#1f1c2e",
    "terminal.background": "#262335",
    "terminal.foreground": "#ffffff",
    "button.background": "#ff7edb",
    "button.foreground": "#262335",
    "button.hoverBackground": "#f97e72",
    "input.background": "#191526",
    "input.foreground": "#ffffff",
    "focusBorder": "#ff7edb",
    "list.activeSelectionBackground": "#463465",
    "list.hoverBackground": "#2e2b40",
    "badge.background": "#ff7edb",
    "badge.foreground": "#262335"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#848bbd",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#ff8b39"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#f97e72"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#fede5d"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#36f9f6"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#ff7edb"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#fe4450"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#36f9f6"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#fe4450",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#36f9f6",
    "class": "#fe4450"
  }
}
