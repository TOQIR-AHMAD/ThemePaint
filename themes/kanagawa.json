{
  "name": "Kanagawa",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1f1f28",
    "editor.foreground": "#dcd7ba",
    "editorLineNumber.foreground": "#727169",
    "editorLineNumber.activeForeground": "#7e9cd8",
    "editor.selectionBackground": "#2d4f67",
    "editor.lineHighlightBackground": "#2a2a37",
    "editorCursor.foreground": "#c8c093",
    "editor.findMatchBackground": "#7e9cd866",
    "editorWhitespace.foreground": "#dcd7ba1a",
    "activityBar.background": "#16161d",
    "activityBar.foreground": "#7e9cd8",
    "activityBar.inactiveForeground": "#727169",
    "activityBarBadge.background": "#7e9cd8",
    "activityBarBadge.foreground": "#1f1f28",
    "sideBar.background": "#1a1a22",
    "sideBar.foreground": "#dcd7ba",
    "sideBarTitle.foreground": "#7e9cd8",
    "sideBarSectionHeader.background": "#1f1f28",
    "statusBar.background": "#16161d",
    "statusBar.foreground": "#dcd7ba",
    "statusBar.noFolderBackground": "#16161d",
    "titleBar.activeBackground": "#16161d",
    "titleBar.activeForeground": "#dcd7ba",
    "editorGroupHeader.tabsBackground": "#1a1a22",
    "tab.activeBackground": "#1f1f28",
    "tab.activeForeground": "#7e9cd8",
    "tab.inactiveBackground": "#1a1a22",
    "tab.inactiveForeground": "#727169",
    "tab.activeBorderTop": "#7e9cd8",
    "panel.background": "#1a1a22",
    "terminal.background": "#1f1f28",
    "terminal.foreground": "#dcd7ba",
    "button.background": "#7e9cd8",
    "button.foreground": "#1f1f28",
    "button.hoverBackground": "#957fb8",
    "input.background": "#16161d",
    "input.foreground": "#dcd7ba",
    "focusBorder": "#7e9cd8",
    "list.activeSelectionBackground": "#2d4f67",
    "list.hoverBackground": "#2a2a37",
    "badge.background": "#7e9cd8",
    "badge.foreground": "#1f1f28"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#727169",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#98bb6c"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#d27e99"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#957fb8"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7e9cd8"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#dcd7ba"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#7aa89f"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#c0a36e"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#7aa89f",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#7e9cd8",
    "class": "#7aa89f"
  }
}
