{
  "name": "Cyber: Blue Team",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#001018",
    "editor.foreground": "#cfe8ff",
    "editorLineNumber.foreground": "#3a6a86",
    "editorLineNumber.activeForeground": "#00b4ff",
    "editor.selectionBackground": "#08344a",
    "editor.lineHighlightBackground": "#021c28",
    "editorCursor.foreground": "#00b4ff",
    "editor.findMatchBackground": "#00b4ff66",
    "editorWhitespace.foreground": "#cfe8ff1a",
    "editorBracketHighlight.foreground1": "#82e0ff",
    "editorBracketHighlight.foreground2": "#5ad1c0",
    "editorBracketHighlight.foreground3": "#00b4ff",
    "activityBar.background": "#000a10",
    "activityBar.foreground": "#00b4ff",
    "activityBar.inactiveForeground": "#3a6a86",
    "activityBarBadge.background": "#00b4ff",
    "activityBarBadge.foreground": "#001018",
    "sideBar.background": "#00141f",
    "sideBar.foreground": "#cfe8ff",
    "sideBarTitle.foreground": "#00b4ff",
    "sideBarSectionHeader.background": "#001018",
    "statusBar.background": "#000a10",
    "statusBar.foreground": "#cfe8ff",
    "statusBar.noFolderBackground": "#000a10",
    "titleBar.activeBackground": "#000a10",
    "titleBar.activeForeground": "#cfe8ff",
    "editorGroupHeader.tabsBackground": "#00141f",
    "tab.activeBackground": "#001018",
    "tab.activeForeground": "#00b4ff",
    "tab.inactiveBackground": "#00141f",
    "tab.inactiveForeground": "#3a6a86",
    "tab.activeBorderTop": "#00b4ff",
    "panel.background": "#00141f",
    "terminal.background": "#001018",
    "terminal.foreground": "#cfe8ff",
    "button.background": "#00b4ff",
    "button.foreground": "#001018",
    "button.hoverBackground": "#29e0ff",
    "input.background": "#000a10",
    "input.foreground": "#cfe8ff",
    "focusBorder": "#00b4ff",
    "list.activeSelectionBackground": "#08344a",
    "list.hoverBackground": "#021c28",
    "badge.background": "#00b4ff",
    "badge.foreground": "#001018"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#3a6a86",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5ad1c0"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "support.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#ffb703"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#00b4ff"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#29e0ff"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7aa2ff"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#cfe8ff"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#a9c7ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#5fd3ff"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#82e0ff"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#9d7bff"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.type.class",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#5e8bff",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#00b4ff"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9d7bff"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#3a6a86"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#82e0ff",
    "method": "#82e0ff",
    "class": "#5e8bff",
    "interface": "#9d7bff",
    "type": "#9d7bff",
    "enum": "#9d7bff",
    "variable": "#cfe8ff",
    "parameter": "#a9c7ff",
    "property": "#5fd3ff",
    "namespace": "#7aa2ff"
  }
}
