{
  "name": "Vampire",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#282a36",
    "editor.foreground": "#f8f8f2",
    "editorLineNumber.foreground": "#6272a4",
    "editorLineNumber.activeForeground": "#bd93f9",
    "editor.selectionBackground": "#44475a",
    "editor.lineHighlightBackground": "#343746",
    "editorCursor.foreground": "#f8f8f0",
    "editor.findMatchBackground": "#bd93f966",
    "editorWhitespace.foreground": "#f8f8f21a",
    "activityBar.background": "#191a21",
    "activityBar.foreground": "#bd93f9",
    "activityBar.inactiveForeground": "#6272a4",
    "activityBarBadge.background": "#bd93f9",
    "activityBarBadge.foreground": "#282a36",
    "sideBar.background": "#21222c",
    "sideBar.foreground": "#f8f8f2",
    "sideBarTitle.foreground": "#bd93f9",
    "sideBarSectionHeader.background": "#282a36",
    "statusBar.background": "#191a21",
    "statusBar.foreground": "#f8f8f2",
    "statusBar.noFolderBackground": "#191a21",
    "titleBar.activeBackground": "#191a21",
    "titleBar.activeForeground": "#f8f8f2",
    "editorGroupHeader.tabsBackground": "#21222c",
    "tab.activeBackground": "#282a36",
    "tab.activeForeground": "#bd93f9",
    "tab.inactiveBackground": "#21222c",
    "tab.inactiveForeground": "#6272a4",
    "tab.activeBorderTop": "#bd93f9",
    "panel.background": "#21222c",
    "terminal.background": "#282a36",
    "terminal.foreground": "#f8f8f2",
    "button.background": "#bd93f9",
    "button.foreground": "#282a36",
    "button.hoverBackground": "#ff79c6",
    "input.background": "#191a21",
    "input.foreground": "#f8f8f2",
    "focusBorder": "#bd93f9",
    "list.activeSelectionBackground": "#44475a",
    "list.hoverBackground": "#343746",
    "badge.background": "#bd93f9",
    "badge.foreground": "#282a36"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6272a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#f1fa8c"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#bd93f9"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#50fa7b"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8be9fd"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#ff79c6"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#8be9fd",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#50fa7b",
    "class": "#8be9fd"
  }
}
