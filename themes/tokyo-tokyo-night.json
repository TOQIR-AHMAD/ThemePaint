{
  "name": "Tokyo: Tokyo Night",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#a9b1d6",
    "editorLineNumber.foreground": "#5a5f75",
    "editorLineNumber.activeForeground": "#7aa2f7",
    "editor.selectionBackground": "#7aa2f742",
    "editor.lineHighlightBackground": "#282933",
    "editorCursor.foreground": "#7aa2f7",
    "editor.findMatchBackground": "#7aa2f766",
    "editor.findMatchHighlightBackground": "#7aa2f738",
    "editorWhitespace.foreground": "#a9b1d61a",
    "editorIndentGuide.background1": "#a9b1d614",
    "editorIndentGuide.activeBackground1": "#a9b1d638",
    "editorBracketMatch.border": "#7aa2f7",
    "activityBar.background": "#13131b",
    "activityBar.foreground": "#7aa2f7",
    "activityBar.inactiveForeground": "#5a5f75",
    "activityBarBadge.background": "#7aa2f7",
    "activityBarBadge.foreground": "#1a1a1a",
    "sideBar.background": "#161721",
    "sideBar.foreground": "#a9b1d6",
    "sideBarTitle.foreground": "#7aa2f7",
    "sideBarSectionHeader.background": "#1a1b26",
    "statusBar.background": "#13131b",
    "statusBar.foreground": "#a9b1d6",
    "statusBar.noFolderBackground": "#13131b",
    "titleBar.activeBackground": "#13131b",
    "titleBar.activeForeground": "#a9b1d6",
    "titleBar.inactiveBackground": "#13131b",
    "titleBar.inactiveForeground": "#5a5f75",
    "editorGroupHeader.tabsBackground": "#171822",
    "tab.activeBackground": "#1a1b26",
    "tab.activeForeground": "#7aa2f7",
    "tab.inactiveBackground": "#171822",
    "tab.inactiveForeground": "#5a5f75",
    "tab.activeBorderTop": "#7aa2f7",
    "tab.border": "#171822",
    "panel.background": "#161721",
    "panelTitle.activeForeground": "#7aa2f7",
    "terminal.background": "#1a1b26",
    "terminal.foreground": "#a9b1d6",
    "button.background": "#7aa2f7",
    "button.foreground": "#1a1a1a",
    "button.hoverBackground": "#8aadf8",
    "input.background": "#13131b",
    "input.foreground": "#a9b1d6",
    "input.placeholderForeground": "#5a5f75",
    "dropdown.background": "#13131b",
    "focusBorder": "#7aa2f7",
    "list.activeSelectionBackground": "#7aa2f742",
    "list.activeSelectionForeground": "#a9b1d6",
    "list.hoverBackground": "#282933",
    "list.inactiveSelectionBackground": "#7aa2f724",
    "badge.background": "#7aa2f7",
    "badge.foreground": "#1a1a1a",
    "scrollbarSlider.background": "#a9b1d629",
    "scrollbarSlider.hoverBackground": "#a9b1d642",
    "scrollbarSlider.activeBackground": "#a9b1d65c",
    "editorWidget.background": "#13131b",
    "editorSuggestWidget.selectedBackground": "#7aa2f742",
    "selection.background": "#7aa2f74d"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#565f89",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#c0caf5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#a2abd0"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#2ac3de"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#73daca"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89ddff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#2ac3de",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#7aa2f7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#1a1b26",
        "background": "#bb9af7"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#7aa2f7",
    "method": "#7aa2f7",
    "class": "#2ac3de",
    "property": "#73daca",
    "parameter": "#a2abd0",
    "variable": "#c0caf5"
  }
}
