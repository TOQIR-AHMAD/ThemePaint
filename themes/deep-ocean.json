{
  "name": "Deep Ocean",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#011627",
    "editor.foreground": "#d6deeb",
    "editorLineNumber.foreground": "#5f7e97",
    "editorLineNumber.activeForeground": "#82aaff",
    "editor.selectionBackground": "#1d3b53",
    "editor.lineHighlightBackground": "#0b2942",
    "editorCursor.foreground": "#80a4c2",
    "editor.findMatchBackground": "#82aaff66",
    "editorWhitespace.foreground": "#d6deeb1a",
    "activityBar.background": "#010e1a",
    "activityBar.foreground": "#82aaff",
    "activityBar.inactiveForeground": "#5f7e97",
    "activityBarBadge.background": "#82aaff",
    "activityBarBadge.foreground": "#011627",
    "sideBar.background": "#01101d",
    "sideBar.foreground": "#d6deeb",
    "sideBarTitle.foreground": "#82aaff",
    "sideBarSectionHeader.background": "#011627",
    "statusBar.background": "#010e1a",
    "statusBar.foreground": "#d6deeb",
    "statusBar.noFolderBackground": "#010e1a",
    "titleBar.activeBackground": "#010e1a",
    "titleBar.activeForeground": "#d6deeb",
    "editorGroupHeader.tabsBackground": "#01101d",
    "tab.activeBackground": "#011627",
    "tab.activeForeground": "#82aaff",
    "tab.inactiveBackground": "#01101d",
    "tab.inactiveForeground": "#5f7e97",
    "tab.activeBorderTop": "#82aaff",
    "panel.background": "#01101d",
    "terminal.background": "#011627",
    "terminal.foreground": "#d6deeb",
    "button.background": "#82aaff",
    "button.foreground": "#011627",
    "button.hoverBackground": "#7e57c2",
    "input.background": "#010e1a",
    "input.foreground": "#d6deeb",
    "focusBorder": "#82aaff",
    "list.activeSelectionBackground": "#1d3b53",
    "list.hoverBackground": "#0b2942",
    "badge.background": "#82aaff",
    "badge.foreground": "#011627"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#637777",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#ecc48d"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#f78c6c"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#82aaff"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#d6deeb"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffcb8b"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#ffcb8b",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#82aaff",
    "class": "#ffcb8b"
  }
}
