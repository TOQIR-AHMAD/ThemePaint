{
  "name": "GitHub Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0d1117",
    "editor.foreground": "#c9d1d9",
    "editorLineNumber.foreground": "#8b949e",
    "editorLineNumber.activeForeground": "#58a6ff",
    "editor.selectionBackground": "#163356",
    "editor.lineHighlightBackground": "#161b22",
    "editorCursor.foreground": "#58a6ff",
    "editor.findMatchBackground": "#58a6ff66",
    "editorWhitespace.foreground": "#c9d1d91a",
    "activityBar.background": "#010409",
    "activityBar.foreground": "#58a6ff",
    "activityBar.inactiveForeground": "#8b949e",
    "activityBarBadge.background": "#58a6ff",
    "activityBarBadge.foreground": "#0d1117",
    "sideBar.background": "#010409",
    "sideBar.foreground": "#c9d1d9",
    "sideBarTitle.foreground": "#58a6ff",
    "sideBarSectionHeader.background": "#0d1117",
    "statusBar.background": "#010409",
    "statusBar.foreground": "#c9d1d9",
    "statusBar.noFolderBackground": "#010409",
    "titleBar.activeBackground": "#010409",
    "titleBar.activeForeground": "#c9d1d9",
    "editorGroupHeader.tabsBackground": "#010409",
    "tab.activeBackground": "#0d1117",
    "tab.activeForeground": "#58a6ff",
    "tab.inactiveBackground": "#010409",
    "tab.inactiveForeground": "#8b949e",
    "tab.activeBorderTop": "#58a6ff",
    "panel.background": "#010409",
    "terminal.background": "#0d1117",
    "terminal.foreground": "#c9d1d9",
    "button.background": "#58a6ff",
    "button.foreground": "#0d1117",
    "button.hoverBackground": "#1f6feb",
    "input.background": "#010409",
    "input.foreground": "#c9d1d9",
    "focusBorder": "#58a6ff",
    "list.activeSelectionBackground": "#163356",
    "list.hoverBackground": "#161b22",
    "badge.background": "#58a6ff",
    "badge.foreground": "#0d1117"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#8b949e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a5d6ff"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#79c0ff"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#d2a8ff"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#c9d1d9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffa657"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#ff7b72"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#7ee787",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#d2a8ff",
    "class": "#7ee787"
  }
}
