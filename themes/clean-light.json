{
  "name": "Clean Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#1f2328",
    "editorLineNumber.foreground": "#9aa0a6",
    "editorLineNumber.activeForeground": "#1f2328",
    "editor.selectionBackground": "#cfe3ff",
    "editor.lineHighlightBackground": "#f3f4f6",
    "editorCursor.foreground": "#0969da",
    "editor.findMatchBackground": "#ffd33d66",
    "activityBar.background": "#f6f8fa",
    "activityBar.foreground": "#0969da",
    "activityBar.inactiveForeground": "#57606a",
    "activityBarBadge.background": "#0969da",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#f6f8fa",
    "sideBar.foreground": "#1f2328",
    "sideBarTitle.foreground": "#1f2328",
    "sideBarSectionHeader.background": "#eaeef2",
    "statusBar.background": "#0969da",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#0969da",
    "titleBar.activeBackground": "#f6f8fa",
    "titleBar.activeForeground": "#1f2328",
    "editorGroupHeader.tabsBackground": "#f6f8fa",
    "tab.activeBackground": "#ffffff",
    "tab.activeForeground": "#1f2328",
    "tab.inactiveBackground": "#f6f8fa",
    "tab.inactiveForeground": "#57606a",
    "tab.activeBorderTop": "#0969da",
    "panel.background": "#ffffff",
    "terminal.background": "#ffffff",
    "terminal.foreground": "#1f2328",
    "button.background": "#0969da",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#0860c8",
    "input.background": "#ffffff",
    "input.foreground": "#1f2328",
    "input.border": "#d0d7de",
    "focusBorder": "#0969da",
    "list.activeSelectionBackground": "#cfe3ff",
    "list.activeSelectionForeground": "#1f2328",
    "list.hoverBackground": "#eaeef2",
    "badge.background": "#0969da",
    "badge.foreground": "#ffffff"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#6e7781", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#0a3069" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#0550ae" } },
    { "scope": "keyword", "settings": { "foreground": "#cf222e" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#8250df" } },
    { "scope": ["variable", "meta.definition.variable.name"], "settings": { "foreground": "#1f2328" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#953800" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#cf222e" } },
    { "scope": "entity.name.type.class", "settings": { "foreground": "#953800", "fontStyle": "bold" } }
  ],
  "semanticTokenColors": {
    "function": "#8250df",
    "class": "#953800"
  }
}
