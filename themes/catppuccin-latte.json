{
  "name": "Catppuccin Latte",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#eff1f5",
    "editor.foreground": "#4c4f69",
    "editorLineNumber.foreground": "#8c8fa1",
    "editorLineNumber.activeForeground": "#1e66f5",
    "editor.selectionBackground": "#ccd0da",
    "editor.lineHighlightBackground": "#e6e9ef",
    "editorCursor.foreground": "#dc8a78",
    "editor.findMatchBackground": "#1e66f566",
    "editorWhitespace.foreground": "#4c4f691a",
    "activityBar.background": "#dce0e8",
    "activityBar.foreground": "#1e66f5",
    "activityBar.inactiveForeground": "#8c8fa1",
    "activityBarBadge.background": "#1e66f5",
    "activityBarBadge.foreground": "#eff1f5",
    "sideBar.background": "#e6e9ef",
    "sideBar.foreground": "#4c4f69",
    "sideBarTitle.foreground": "#1e66f5",
    "sideBarSectionHeader.background": "#eff1f5",
    "statusBar.background": "#dce0e8",
    "statusBar.foreground": "#4c4f69",
    "statusBar.noFolderBackground": "#dce0e8",
    "titleBar.activeBackground": "#dce0e8",
    "titleBar.activeForeground": "#4c4f69",
    "editorGroupHeader.tabsBackground": "#e6e9ef",
    "tab.activeBackground": "#eff1f5",
    "tab.activeForeground": "#1e66f5",
    "tab.inactiveBackground": "#e6e9ef",
    "tab.inactiveForeground": "#8c8fa1",
    "tab.activeBorderTop": "#1e66f5",
    "panel.background": "#e6e9ef",
    "terminal.background": "#eff1f5",
    "terminal.foreground": "#4c4f69",
    "button.background": "#1e66f5",
    "button.foreground": "#eff1f5",
    "button.hoverBackground": "#ea76cb",
    "input.background": "#dce0e8",
    "input.foreground": "#4c4f69",
    "focusBorder": "#1e66f5",
    "list.activeSelectionBackground": "#ccd0da",
    "list.hoverBackground": "#e6e9ef",
    "badge.background": "#1e66f5",
    "badge.foreground": "#eff1f5"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#8c8fa1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#40a02b"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#fe640b"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#8839ef"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#1e66f5"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#4c4f69"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#df8e1d"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#04a5e5"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#df8e1d",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#1e66f5",
    "class": "#df8e1d"
  }
}
