  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6a7560",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#a3c585"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#e0b15c"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c5d86d"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#9bbf65"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#cdd6c0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#aeb7a3"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#7fb685"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#d97e6a"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#8cc084"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#c5d86d"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#9bbf65"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e0b15c"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#7fb685",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#9bbf65",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#21281f",
        "background": "#c5d86d"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#9bbf65",
    "method": "#9bbf65",
    "class": "#7fb685",
    "property": "#d97e6a",
    "parameter": "#aeb7a3",
    "variable": "#cdd6c0"
  }
}
