{
  "name": "Tokyo Night",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#a9b1d6",
    "editorLineNumber.foreground": "#565f89",
    "editorLineNumber.activeForeground": "#7aa2f7",
    "editor.selectionBackground": "#283457",
    "editor.lineHighlightBackground": "#1e202e",
    "editorCursor.foreground": "#c0caf5",
    "editor.findMatchBackground": "#7aa2f766",
    "editorWhitespace.foreground": "#a9b1d61a",
    "activityBar.background": "#13131a",
    "activityBar.foreground": "#7aa2f7",
    "activityBar.inactiveForeground": "#565f89",
    "activityBarBadge.background": "#7aa2f7",
    "activityBarBadge.foreground": "#1a1b26",
    "sideBar.background": "#16161e",
    "sideBar.foreground": "#a9b1d6",
    "sideBarTitle.foreground": "#7aa2f7",
    "sideBarSectionHeader.background": "#1a1b26",
    "statusBar.background": "#13131a",
    "statusBar.foreground": "#a9b1d6",
    "statusBar.noFolderBackground": "#13131a",
    "titleBar.activeBackground": "#13131a",
    "titleBar.activeForeground": "#a9b1d6",
    "editorGroupHeader.tabsBackground": "#16161e",
    "tab.activeBackground": "#1a1b26",
    "tab.activeForeground": "#7aa2f7",
    "tab.inactiveBackground": "#16161e",
    "tab.inactiveForeground": "#565f89",
    "tab.activeBorderTop": "#7aa2f7",
    "panel.background": "#16161e",
    "terminal.background": "#1a1b26",
    "terminal.foreground": "#a9b1d6",
    "button.background": "#7aa2f7",
    "button.foreground": "#1a1b26",
    "button.hoverBackground": "#bb9af7",
    "input.background": "#13131a",
    "input.foreground": "#a9b1d6",
    "focusBorder": "#7aa2f7",
    "list.activeSelectionBackground": "#283457",
    "list.hoverBackground": "#1e202e",
    "badge.background": "#7aa2f7",
    "badge.foreground": "#1a1b26"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#565f89",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7aa2f7"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#c0caf5"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#2ac3de"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89ddff"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#2ac3de",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#7aa2f7",
    "class": "#2ac3de"
  }
}
