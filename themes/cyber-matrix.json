{
  "name": "Cyber: Matrix",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#d6ffe0",
    "editorLineNumber.foreground": "#2f6b39",
    "editorLineNumber.activeForeground": "#00ff41",
    "editor.selectionBackground": "#0a3d12",
    "editor.lineHighlightBackground": "#04140a",
    "editorCursor.foreground": "#00ff41",
    "editor.findMatchBackground": "#00ff4166",
    "editorWhitespace.foreground": "#d6ffe01a",
    "editorBracketHighlight.foreground1": "#39d0d8",
    "editorBracketHighlight.foreground2": "#b8ff9e",
    "editorBracketHighlight.foreground3": "#00ff41",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#00ff41",
    "activityBar.inactiveForeground": "#2f6b39",
    "activityBarBadge.background": "#00ff41",
    "activityBarBadge.foreground": "#000000",
    "sideBar.background": "#02160a",
    "sideBar.foreground": "#d6ffe0",
    "sideBarTitle.foreground": "#00ff41",
    "sideBarSectionHeader.background": "#000000",
    "statusBar.background": "#000000",
    "statusBar.foreground": "#d6ffe0",
    "statusBar.noFolderBackground": "#000000",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#d6ffe0",
    "editorGroupHeader.tabsBackground": "#02160a",
    "tab.activeBackground": "#000000",
    "tab.activeForeground": "#00ff41",
    "tab.inactiveBackground": "#02160a",
    "tab.inactiveForeground": "#2f6b39",
    "tab.activeBorderTop": "#00ff41",
    "panel.background": "#02160a",
    "terminal.background": "#000000",
    "terminal.foreground": "#d6ffe0",
    "button.background": "#00ff41",
    "button.foreground": "#000000",
    "button.hoverBackground": "#39ff14",
    "input.background": "#000000",
    "input.foreground": "#d6ffe0",
    "focusBorder": "#00ff41",
    "list.activeSelectionBackground": "#0a3d12",
    "list.hoverBackground": "#04140a",
    "badge.background": "#00ff41",
    "badge.foreground": "#000000"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#3fa34d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#b8ff9e"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#fff07c"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "support.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#ffd166"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#00ff41"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#00ff9f"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00d0ff"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#d6ffe0"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#b6f7ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#7cfc00"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#39d0d8"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#aaff00"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.type.class",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#00ffa3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#00ff41"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#aaff00"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#2f6b39"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#39d0d8",
    "method": "#39d0d8",
    "class": "#00ffa3",
    "interface": "#aaff00",
    "type": "#aaff00",
    "enum": "#aaff00",
    "variable": "#d6ffe0",
    "parameter": "#b6f7ff",
    "property": "#7cfc00",
    "namespace": "#00d0ff"
  }
}
