{
  "name": "Palenight",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#292d3e",
    "editor.foreground": "#a6accd",
    "editorLineNumber.foreground": "#676e95",
    "editorLineNumber.activeForeground": "#82aaff",
    "editor.selectionBackground": "#3c435e",
    "editor.lineHighlightBackground": "#2f3447",
    "editorCursor.foreground": "#ffcc00",
    "editor.findMatchBackground": "#82aaff66",
    "editorWhitespace.foreground": "#a6accd1a",
    "activityBar.background": "#1b1e2b",
    "activityBar.foreground": "#82aaff",
    "activityBar.inactiveForeground": "#676e95",
    "activityBarBadge.background": "#82aaff",
    "activityBarBadge.foreground": "#292d3e",
    "sideBar.background": "#222533",
    "sideBar.foreground": "#a6accd",
    "sideBarTitle.foreground": "#82aaff",
    "sideBarSectionHeader.background": "#292d3e",
    "statusBar.background": "#1b1e2b",
    "statusBar.foreground": "#a6accd",
    "statusBar.noFolderBackground": "#1b1e2b",
    "titleBar.activeBackground": "#1b1e2b",
    "titleBar.activeForeground": "#a6accd",
    "editorGroupHeader.tabsBackground": "#222533",
    "tab.activeBackground": "#292d3e",
    "tab.activeForeground": "#82aaff",
    "tab.inactiveBackground": "#222533",
    "tab.inactiveForeground": "#676e95",
    "tab.activeBorderTop": "#82aaff",
    "panel.background": "#222533",
    "terminal.background": "#292d3e",
    "terminal.foreground": "#a6accd",
    "button.background": "#82aaff",
    "button.foreground": "#292d3e",
    "button.hoverBackground": "#c792ea",
    "input.background": "#1b1e2b",
    "input.foreground": "#a6accd",
    "focusBorder": "#82aaff",
    "list.activeSelectionBackground": "#3c435e",
    "list.hoverBackground": "#2f3447",
    "badge.background": "#82aaff",
    "badge.foreground": "#292d3e"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#676e95",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#c3e88d"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#f78c6c"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#82aaff"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#a6accd"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89ddff"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#ffcb6b",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#82aaff",
    "class": "#ffcb6b"
  }
}
