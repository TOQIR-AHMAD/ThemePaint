  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#4a6378",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#80cbc4"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#ffab70"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#90caf9"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#29b6f6"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#aab8c5"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#8d9ba9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#f6c177"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#f48fb1"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#4dd0e1"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#90caf9"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#29b6f6"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#ffab70"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#f6c177",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#29b6f6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#0a1929",
        "background": "#90caf9"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#29b6f6",
    "method": "#29b6f6",
    "class": "#f6c177",
    "property": "#f48fb1",
    "parameter": "#8d9ba9",
    "variable": "#aab8c5"
  }
}
