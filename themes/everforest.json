{
  "name": "Everforest",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#2b3339",
    "editor.foreground": "#d3c6aa",
    "editorLineNumber.foreground": "#859289",
    "editorLineNumber.activeForeground": "#a7c080",
    "editor.selectionBackground": "#3a454a",
    "editor.lineHighlightBackground": "#323c41",
    "editorCursor.foreground": "#d3c6aa",
    "editor.findMatchBackground": "#a7c08066",
    "editorWhitespace.foreground": "#d3c6aa1a",
    "activityBar.background": "#1e2326",
    "activityBar.foreground": "#a7c080",
    "activityBar.inactiveForeground": "#859289",
    "activityBarBadge.background": "#a7c080",
    "activityBarBadge.foreground": "#2b3339",
    "sideBar.background": "#232a2e",
    "sideBar.foreground": "#d3c6aa",
    "sideBarTitle.foreground": "#a7c080",
    "sideBarSectionHeader.background": "#2b3339",
    "statusBar.background": "#1e2326",
    "statusBar.foreground": "#d3c6aa",
    "statusBar.noFolderBackground": "#1e2326",
    "titleBar.activeBackground": "#1e2326",
    "titleBar.activeForeground": "#d3c6aa",
    "editorGroupHeader.tabsBackground": "#232a2e",
    "tab.activeBackground": "#2b3339",
    "tab.activeForeground": "#a7c080",
    "tab.inactiveBackground": "#232a2e",
    "tab.inactiveForeground": "#859289",
    "tab.activeBorderTop": "#a7c080",
    "panel.background": "#232a2e",
    "terminal.background": "#2b3339",
    "terminal.foreground": "#d3c6aa",
    "button.background": "#a7c080",
    "button.foreground": "#2b3339",
    "button.hoverBackground": "#7fbbb3",
    "input.background": "#1e2326",
    "input.foreground": "#d3c6aa",
    "focusBorder": "#a7c080",
    "list.activeSelectionBackground": "#3a454a",
    "list.hoverBackground": "#323c41",
    "badge.background": "#a7c080",
    "badge.foreground": "#2b3339"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#859289",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a7c080"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#d699b6"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#e67e80"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#a7c080"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#d3c6aa"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#dbbc7f"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#e69875"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#dbbc7f",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#a7c080",
    "class": "#dbbc7f"
  }
}
