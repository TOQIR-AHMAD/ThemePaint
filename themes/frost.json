{
  "name": "Frost",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#2e3440",
    "editor.foreground": "#d8dee9",
    "editorLineNumber.foreground": "#4c566a",
    "editorLineNumber.activeForeground": "#88c0d0",
    "editor.selectionBackground": "#434c5e",
    "editor.lineHighlightBackground": "#3b4252",
    "editorCursor.foreground": "#d8dee9",
    "editor.findMatchBackground": "#88c0d066",
    "editorWhitespace.foreground": "#d8dee91a",
    "activityBar.background": "#272c36",
    "activityBar.foreground": "#88c0d0",
    "activityBar.inactiveForeground": "#4c566a",
    "activityBarBadge.background": "#88c0d0",
    "activityBarBadge.foreground": "#2e3440",
    "sideBar.background": "#2b303b",
    "sideBar.foreground": "#d8dee9",
    "sideBarTitle.foreground": "#88c0d0",
    "sideBarSectionHeader.background": "#2e3440",
    "statusBar.background": "#272c36",
    "statusBar.foreground": "#d8dee9",
    "statusBar.noFolderBackground": "#272c36",
    "titleBar.activeBackground": "#272c36",
    "titleBar.activeForeground": "#d8dee9",
    "editorGroupHeader.tabsBackground": "#2b303b",
    "tab.activeBackground": "#2e3440",
    "tab.activeForeground": "#88c0d0",
    "tab.inactiveBackground": "#2b303b",
    "tab.inactiveForeground": "#4c566a",
    "tab.activeBorderTop": "#88c0d0",
    "panel.background": "#2b303b",
    "terminal.background": "#2e3440",
    "terminal.foreground": "#d8dee9",
    "button.background": "#88c0d0",
    "button.foreground": "#2e3440",
    "button.hoverBackground": "#81a1c1",
    "input.background": "#272c36",
    "input.foreground": "#d8dee9",
    "focusBorder": "#88c0d0",
    "list.activeSelectionBackground": "#434c5e",
    "list.hoverBackground": "#3b4252",
    "badge.background": "#88c0d0",
    "badge.foreground": "#2e3440"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#616e88",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a3be8c"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#b48ead"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#81a1c1"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#88c0d0"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#d8dee9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8fbcbb"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#81a1c1"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#8fbcbb",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#88c0d0",
    "class": "#8fbcbb"
  }
}
