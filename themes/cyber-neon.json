{
  "name": "Cyber: Neon City",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0d0221",
    "editor.foreground": "#f6f6ff",
    "editorLineNumber.foreground": "#6c5b9e",
    "editorLineNumber.activeForeground": "#00fff5",
    "editor.selectionBackground": "#2a1a4a",
    "editor.lineHighlightBackground": "#140833",
    "editorCursor.foreground": "#ff2a6d",
    "editor.findMatchBackground": "#00fff566",
    "editorWhitespace.foreground": "#f6f6ff1a",
    "editorBracketHighlight.foreground1": "#05d9e8",
    "editorBracketHighlight.foreground2": "#a6ff00",
    "editorBracketHighlight.foreground3": "#fb4dff",
    "activityBar.background": "#060110",
    "activityBar.foreground": "#00fff5",
    "activityBar.inactiveForeground": "#6c5b9e",
    "activityBarBadge.background": "#00fff5",
    "activityBarBadge.foreground": "#0d0221",
    "sideBar.background": "#0a021a",
    "sideBar.foreground": "#f6f6ff",
    "sideBarTitle.foreground": "#00fff5",
    "sideBarSectionHeader.background": "#0d0221",
    "statusBar.background": "#060110",
    "statusBar.foreground": "#f6f6ff",
    "statusBar.noFolderBackground": "#060110",
    "titleBar.activeBackground": "#060110",
    "titleBar.activeForeground": "#f6f6ff",
    "editorGroupHeader.tabsBackground": "#0a021a",
    "tab.activeBackground": "#0d0221",
    "tab.activeForeground": "#00fff5",
    "tab.inactiveBackground": "#0a021a",
    "tab.inactiveForeground": "#6c5b9e",
    "tab.activeBorderTop": "#00fff5",
    "panel.background": "#0a021a",
    "terminal.background": "#0d0221",
    "terminal.foreground": "#f6f6ff",
    "button.background": "#00fff5",
    "button.foreground": "#0d0221",
    "button.hoverBackground": "#ff2a6d",
    "input.background": "#060110",
    "input.foreground": "#f6f6ff",
    "focusBorder": "#00fff5",
    "list.activeSelectionBackground": "#2a1a4a",
    "list.hoverBackground": "#140833",
    "badge.background": "#00fff5",
    "badge.foreground": "#0d0221"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6c5b9e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#a6ff00"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ffd60a"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "support.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#ff9f1c"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#fb4dff"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#d300c5"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ff2a6d"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#f6f6ff"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c4b5ff",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#7afcff"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#05d9e8"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#b6ff5a"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.type.class",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#ff71ce",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#fb4dff"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b6ff5a"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6c5b9e"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#05d9e8",
    "method": "#05d9e8",
    "class": "#ff71ce",
    "interface": "#b6ff5a",
    "type": "#b6ff5a",
    "enum": "#b6ff5a",
    "variable": "#f6f6ff",
    "parameter": "#c4b5ff",
    "property": "#7afcff",
    "namespace": "#ff2a6d"
  }
}
