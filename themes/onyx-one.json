{
  "name": "Onyx One",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#282c34",
    "editor.foreground": "#abb2bf",
    "editorLineNumber.foreground": "#5c6370",
    "editorLineNumber.activeForeground": "#61afef",
    "editor.selectionBackground": "#3e4451",
    "editor.lineHighlightBackground": "#2c313a",
    "editorCursor.foreground": "#61afef",
    "editor.findMatchBackground": "#61afef66",
    "editorWhitespace.foreground": "#abb2bf1a",
    "activityBar.background": "#1b1f23",
    "activityBar.foreground": "#61afef",
    "activityBar.inactiveForeground": "#5c6370",
    "activityBarBadge.background": "#61afef",
    "activityBarBadge.foreground": "#ffffff",
    "sideBar.background": "#21252b",
    "sideBar.foreground": "#abb2bf",
    "sideBarTitle.foreground": "#61afef",
    "sideBarSectionHeader.background": "#282c34",
    "statusBar.background": "#1b1f23",
    "statusBar.foreground": "#abb2bf",
    "statusBar.noFolderBackground": "#1b1f23",
    "titleBar.activeBackground": "#1b1f23",
    "titleBar.activeForeground": "#abb2bf",
    "editorGroupHeader.tabsBackground": "#21252b",
    "tab.activeBackground": "#282c34",
    "tab.activeForeground": "#61afef",
    "tab.inactiveBackground": "#21252b",
    "tab.inactiveForeground": "#5c6370",
    "tab.activeBorderTop": "#61afef",
    "panel.background": "#21252b",
    "terminal.background": "#282c34",
    "terminal.foreground": "#abb2bf",
    "button.background": "#61afef",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#528bff",
    "input.background": "#1b1f23",
    "input.foreground": "#abb2bf",
    "focusBorder": "#61afef",
    "list.activeSelectionBackground": "#3e4451",
    "list.hoverBackground": "#2c313a",
    "badge.background": "#61afef",
    "badge.foreground": "#ffffff"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#5c6370",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#61afef"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#e5c07b",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#61afef",
    "class": "#e5c07b"
  }
}
