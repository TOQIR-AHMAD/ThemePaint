{
  "name": "Andromeda",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#23262e",
    "editor.foreground": "#d5ced9",
    "editorLineNumber.foreground": "#707070",
    "editorLineNumber.activeForeground": "#00e8c6",
    "editor.selectionBackground": "#383b45",
    "editor.lineHighlightBackground": "#2b2e36",
    "editorCursor.foreground": "#fc644d",
    "editor.findMatchBackground": "#00e8c666",
    "editorWhitespace.foreground": "#d5ced91a",
    "activityBar.background": "#1b1e24",
    "activityBar.foreground": "#00e8c6",
    "activityBar.inactiveForeground": "#707070",
    "activityBarBadge.background": "#00e8c6",
    "activityBarBadge.foreground": "#23262e",
    "sideBar.background": "#1e2127",
    "sideBar.foreground": "#d5ced9",
    "sideBarTitle.foreground": "#00e8c6",
    "sideBarSectionHeader.background": "#23262e",
    "statusBar.background": "#1b1e24",
    "statusBar.foreground": "#d5ced9",
    "statusBar.noFolderBackground": "#1b1e24",
    "titleBar.activeBackground": "#1b1e24",
    "titleBar.activeForeground": "#d5ced9",
    "editorGroupHeader.tabsBackground": "#1e2127",
    "tab.activeBackground": "#23262e",
    "tab.activeForeground": "#00e8c6",
    "tab.inactiveBackground": "#1e2127",
    "tab.inactiveForeground": "#707070",
    "tab.activeBorderTop": "#00e8c6",
    "panel.background": "#1e2127",
    "terminal.background": "#23262e",
    "terminal.foreground": "#d5ced9",
    "button.background": "#00e8c6",
    "button.foreground": "#23262e",
    "button.hoverBackground": "#ee5d43",
    "input.background": "#1b1e24",
    "input.foreground": "#d5ced9",
    "focusBorder": "#00e8c6",
    "list.activeSelectionBackground": "#383b45",
    "list.hoverBackground": "#2b2e36",
    "badge.background": "#00e8c6",
    "badge.foreground": "#23262e"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#707070",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#96e072"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#f39c12"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#c74ded"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#00e8c6"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#d5ced9"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffe66d"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#ee5d43"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#ffe66d",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#00e8c6",
    "class": "#ffe66d"
  }
}
