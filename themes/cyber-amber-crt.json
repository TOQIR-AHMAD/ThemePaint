{
  "name": "Cyber: Amber CRT",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#0a0a00",
    "editor.foreground": "#ffcf6b",
    "editorLineNumber.foreground": "#7a6a3a",
    "editorLineNumber.activeForeground": "#ffb000",
    "editor.selectionBackground": "#3a2a00",
    "editor.lineHighlightBackground": "#141000",
    "editorCursor.foreground": "#ffb000",
    "editor.findMatchBackground": "#ffb00066",
    "editorWhitespace.foreground": "#ffcf6b1a",
    "editorBracketHighlight.foreground1": "#ffd24a",
    "editorBracketHighlight.foreground2": "#ffe08a",
    "editorBracketHighlight.foreground3": "#ffb000",
    "activityBar.background": "#050500",
    "activityBar.foreground": "#ffb000",
    "activityBar.inactiveForeground": "#7a6a3a",
    "activityBarBadge.background": "#ffb000",
    "activityBarBadge.foreground": "#0a0a00",
    "sideBar.background": "#0d0d00",
    "sideBar.foreground": "#ffcf6b",
    "sideBarTitle.foreground": "#ffb000",
    "sideBarSectionHeader.background": "#0a0a00",
    "statusBar.background": "#050500",
    "statusBar.foreground": "#ffcf6b",
    "statusBar.noFolderBackground": "#050500",
    "titleBar.activeBackground": "#050500",
    "titleBar.activeForeground": "#ffcf6b",
    "editorGroupHeader.tabsBackground": "#0d0d00",
    "tab.activeBackground": "#0a0a00",
    "tab.activeForeground": "#ffb000",
    "tab.inactiveBackground": "#0d0d00",
    "tab.inactiveForeground": "#7a6a3a",
    "tab.activeBorderTop": "#ffb000",
    "panel.background": "#0d0d00",
    "terminal.background": "#0a0a00",
    "terminal.foreground": "#ffcf6b",
    "button.background": "#ffb000",
    "button.foreground": "#0a0a00",
    "button.hoverBackground": "#ffd700",
    "input.background": "#050500",
    "input.foreground": "#ffcf6b",
    "focusBorder": "#ffb000",
    "list.activeSelectionBackground": "#3a2a00",
    "list.hoverBackground": "#141000",
    "badge.background": "#ffb000",
    "badge.foreground": "#0a0a00"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6e6a3a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#ffe08a"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ff8c00"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant.language",
        "constant.character",
        "support.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#ff6f00"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#ffb000"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#ffa94d"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ffd700"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#ffcf6b"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#ffdf9e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#ffb86c"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#ffd24a"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#ff9e3d"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.type.class",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#fff0b3",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#ffb000"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ff9e3d"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#7a6a3a"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#ffd24a",
    "method": "#ffd24a",
    "class": "#fff0b3",
    "interface": "#ff9e3d",
    "type": "#ff9e3d",
    "enum": "#ff9e3d",
    "variable": "#ffcf6b",
    "parameter": "#ffdf9e",
    "property": "#ffb86c",
    "namespace": "#ffd700"
  }
}
