{
  "name": "Solar Day",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#fdf6e3",
    "editor.foreground": "#657b83",
    "editorLineNumber.foreground": "#93a1a1",
    "editorLineNumber.activeForeground": "#268bd2",
    "editor.selectionBackground": "#d8d2bf",
    "editor.lineHighlightBackground": "#eee8d5",
    "editorCursor.foreground": "#586e75",
    "editor.findMatchBackground": "#268bd266",
    "editorWhitespace.foreground": "#657b831a",
    "activityBar.background": "#eee8d5",
    "activityBar.foreground": "#268bd2",
    "activityBar.inactiveForeground": "#93a1a1",
    "activityBarBadge.background": "#268bd2",
    "activityBarBadge.foreground": "#fdf6e3",
    "sideBar.background": "#eee8d5",
    "sideBar.foreground": "#657b83",
    "sideBarTitle.foreground": "#268bd2",
    "sideBarSectionHeader.background": "#fdf6e3",
    "statusBar.background": "#eee8d5",
    "statusBar.foreground": "#657b83",
    "statusBar.noFolderBackground": "#eee8d5",
    "titleBar.activeBackground": "#eee8d5",
    "titleBar.activeForeground": "#657b83",
    "editorGroupHeader.tabsBackground": "#eee8d5",
    "tab.activeBackground": "#fdf6e3",
    "tab.activeForeground": "#268bd2",
    "tab.inactiveBackground": "#eee8d5",
    "tab.inactiveForeground": "#93a1a1",
    "tab.activeBorderTop": "#268bd2",
    "panel.background": "#eee8d5",
    "terminal.background": "#fdf6e3",
    "terminal.foreground": "#657b83",
    "button.background": "#268bd2",
    "button.foreground": "#fdf6e3",
    "button.hoverBackground": "#2aa198",
    "input.background": "#eee8d5",
    "input.foreground": "#657b83",
    "focusBorder": "#268bd2",
    "list.activeSelectionBackground": "#d8d2bf",
    "list.hoverBackground": "#eee8d5",
    "badge.background": "#268bd2",
    "badge.foreground": "#fdf6e3"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#93a1a1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#2aa198"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#d33682"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#859900"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#268bd2"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#657b83"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b58900"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#859900"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#b58900",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#268bd2",
    "class": "#b58900"
  }
}
