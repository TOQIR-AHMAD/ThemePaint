{
  "name": "Cobalt Forge",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#193549",
    "editor.foreground": "#ffffff",
    "editorLineNumber.foreground": "#aaaaaa55",
    "editorLineNumber.activeForeground": "#ffc600",
    "editor.selectionBackground": "#0050a4",
    "editor.lineHighlightBackground": "#1f4662",
    "editorCursor.foreground": "#ffc600",
    "editor.findMatchBackground": "#ffc60099",
    "editorWhitespace.foreground": "#ffffff1a",
    "activityBar.background": "#122738",
    "activityBar.foreground": "#ffc600",
    "activityBar.inactiveForeground": "#ffffff66",
    "activityBarBadge.background": "#ffc600",
    "activityBarBadge.foreground": "#193549",
    "sideBar.background": "#15232d",
    "sideBar.foreground": "#ffffff",
    "sideBarTitle.foreground": "#ffc600",
    "sideBarSectionHeader.background": "#193549",
    "statusBar.background": "#0d3a58",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#0d3a58",
    "titleBar.activeBackground": "#122738",
    "titleBar.activeForeground": "#ffffff",
    "editorGroupHeader.tabsBackground": "#15232d",
    "tab.activeBackground": "#193549",
    "tab.activeForeground": "#ffc600",
    "tab.inactiveBackground": "#15232d",
    "tab.inactiveForeground": "#ffffff80",
    "tab.activeBorderTop": "#ffc600",
    "panel.background": "#15232d",
    "terminal.background": "#193549",
    "terminal.foreground": "#ffffff",
    "button.background": "#1f8acc",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#2ba6e8",
    "input.background": "#122738",
    "input.foreground": "#ffffff",
    "focusBorder": "#1f8acc",
    "list.activeSelectionBackground": "#0050a4",
    "list.hoverBackground": "#1f4662",
    "badge.background": "#ffc600",
    "badge.foreground": "#193549"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#0088ff", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#3ad900" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#ff628c" } },
    { "scope": "keyword", "settings": { "foreground": "#ff9d00" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#ffc600" } },
    { "scope": ["variable", "meta.definition.variable.name"], "settings": { "foreground": "#ffffff" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#80fcff" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#ff9d00" } },
    { "scope": "entity.name.type.class", "settings": { "foreground": "#80fcff", "fontStyle": "bold" } }
  ],
  "semanticTokenColors": {
    "function": "#ffc600",
    "class": "#80fcff"
  }
}
