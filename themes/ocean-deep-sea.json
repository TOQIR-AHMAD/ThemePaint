    "editorWhitespace.foreground": "#8f93a21a",
    "editorIndentGuide.background1": "#8f93a214",
    "editorIndentGuide.activeBackground1": "#8f93a238",
    "editorBracketMatch.border": "#84ffff",
    "activityBar.background": "#0b0c13",
