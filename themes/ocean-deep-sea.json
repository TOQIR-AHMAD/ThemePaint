    "statusBar.noFolderBackground": "#0b0c13",
    "titleBar.activeBackground": "#0b0c13",
    "titleBar.activeForeground": "#8f93a2",
    "titleBar.inactiveBackground": "#0b0c13",
    "titleBar.inactiveForeground": "#494c57",
    "editorGroupHeader.tabsBackground": "#0e0f17",
    "tab.activeBackground": "#0f111a",
    "tab.activeForeground": "#84ffff",
    "tab.inactiveBackground": "#0e0f17",
    "tab.inactiveForeground": "#494c57",
    "tab.activeBorderTop": "#84ffff",
    "tab.border": "#0e0f17",
    "panel.background": "#0d0f16",
    "panelTitle.activeForeground": "#84ffff",
    "terminal.background": "#0f111a",
    "terminal.foreground": "#8f93a2",
    "button.background": "#84ffff",
    "button.foreground": "#1a1a1a",
    "button.hoverBackground": "#93ffff",
    "input.background": "#0b0c13",
    "input.foreground": "#8f93a2",
    "input.placeholderForeground": "#494c57",
    "dropdown.background": "#0b0c13",
    "focusBorder": "#84ffff",
    "list.activeSelectionBackground": "#84ffff42",
    "list.activeSelectionForeground": "#8f93a2",
    "list.hoverBackground": "#1d1f28",
    "list.inactiveSelectionBackground": "#84ffff24",
    "badge.background": "#84ffff",
    "badge.foreground": "#1a1a1a",
    "scrollbarSlider.background": "#8f93a229",
    "scrollbarSlider.hoverBackground": "#8f93a242",
    "scrollbarSlider.activeBackground": "#8f93a25c",
    "editorWidget.background": "#0b0c13",
    "editorSuggestWidget.selectedBackground": "#84ffff42",
    "selection.background": "#84ffff4d"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#464b5d",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#c3e88d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#f78c6c"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#82aaff"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#8f93a2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#787c8a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#f07178"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89ddff"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#82aaff"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f78c6c"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#ffcb6b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#84ffff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#0f111a",
        "background": "#c792ea"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#82aaff",
    "method": "#82aaff",
    "class": "#ffcb6b",
    "property": "#f07178",
    "parameter": "#787c8a",
    "variable": "#8f93a2"
  }
}
