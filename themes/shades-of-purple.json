{
  "name": "Shades of Purple",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#2d2b55",
    "editor.foreground": "#ffffff",
    "editorLineNumber.foreground": "#a599e9",
    "editorLineNumber.activeForeground": "#fad000",
    "editor.selectionBackground": "#4d4181",
    "editor.lineHighlightBackground": "#353260",
    "editorCursor.foreground": "#fad000",
    "editor.findMatchBackground": "#fad00066",
    "editorWhitespace.foreground": "#ffffff1a",
    "activityBar.background": "#1e1e3f",
    "activityBar.foreground": "#fad000",
    "activityBar.inactiveForeground": "#a599e9",
    "activityBarBadge.background": "#fad000",
    "activityBarBadge.foreground": "#2d2b55",
    "sideBar.background": "#28284a",
    "sideBar.foreground": "#ffffff",
    "sideBarTitle.foreground": "#fad000",
    "sideBarSectionHeader.background": "#2d2b55",
    "statusBar.background": "#1e1e3f",
    "statusBar.foreground": "#ffffff",
    "statusBar.noFolderBackground": "#1e1e3f",
    "titleBar.activeBackground": "#1e1e3f",
    "titleBar.activeForeground": "#ffffff",
    "editorGroupHeader.tabsBackground": "#28284a",
    "tab.activeBackground": "#2d2b55",
    "tab.activeForeground": "#fad000",
    "tab.inactiveBackground": "#28284a",
    "tab.inactiveForeground": "#a599e9",
    "tab.activeBorderTop": "#fad000",
    "panel.background": "#28284a",
    "terminal.background": "#2d2b55",
    "terminal.foreground": "#ffffff",
    "button.background": "#fad000",
    "button.foreground": "#2d2b55",
    "button.hoverBackground": "#ff628c",
    "input.background": "#1e1e3f",
    "input.foreground": "#ffffff",
    "focusBorder": "#fad000",
    "list.activeSelectionBackground": "#4d4181",
    "list.hoverBackground": "#353260",
    "badge.background": "#fad000",
    "badge.foreground": "#2d2b55"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#b362ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#a5ff90"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#ff628c"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#ff9d00"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#fad000"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name"
      ],
      "settings": {
        "foreground": "#ffffff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#9effff"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#ff9d00"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#9effff",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#fad000",
    "class": "#9effff"
  }
}
