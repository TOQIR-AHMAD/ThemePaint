  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#93a1a1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#2aa198"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#d33682"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#859900"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#268bd2"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#657b83"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "parameter"
      ],
      "settings": {
        "foreground": "#809194"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#b58900"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#6c71c4"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#cb4b16"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#859900"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#268bd2"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#d33682"
      }
    },
    {
      "scope": "entity.name.type.class",
      "settings": {
        "foreground": "#b58900",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#268bd2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#fdf6e3",
        "background": "#859900"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#268bd2",
    "method": "#268bd2",
    "class": "#b58900",
    "property": "#6c71c4",
    "parameter": "#809194",
    "variable": "#657b83"
  }
}
