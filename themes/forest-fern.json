    "editorWhitespace.foreground": "#c2d4c41a",
    "editorIndentGuide.background1": "#c2d4c414",
    "editorIndentGuide.activeBackground1": "#c2d4c438",
    "editorBracketMatch.border": "#52b788",
    "activityBar.background": "#101813",
